{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glint",
  "version": "1.0.0",
  "identifier": "dev.peterdsp.glint",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "panel",
        "title": "Glint",
        "width": 360,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFERjMxRDUxRkE1NTlGQTcKUldTbm4xWDZVUjN6clR4OG5TYW5oYlVGSHRGclk0Y3NiTXVRS3A1ckEzWDFpR2h5bzdTNUlEL00K",
      "endpoints": [
        "https://github.com/peterdsp/glint/releases/latest/download/latest.json"
      ]
    }
  }
}
